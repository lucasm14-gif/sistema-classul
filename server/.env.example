# Copie este arquivo para .env e ajuste os valores

# Porta do servidor
PORT=3001

# Senha de acesso ao sistema (web + extensão). MUDE para algo só seu!
API_TOKEN=classul-mude-esta-senha

# Caminho do banco de dados SQLite
DB_PATH=./data/classul.db

# (Opcional) Valores iniciais da Evolution API — também podem ser
# configurados depois pela tela de Configurações do sistema.
EVOLUTION_URL=https://evolution.scalemidia.com.br
EVOLUTION_APIKEY=
EVOLUTION_INSTANCE=
