{
  "manifest_version": 3,
  "name": "Classul - Pedidos WhatsApp",
  "version": "2.0.0",
  "description": "Cria pedidos no sistema Classul direto do WhatsApp Web.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://*/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "placa-homenagem.svg",
        "placa-homenagem-veludo-luxo.png"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ]
}
